---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import Card from '../components/Card.astro'; import areas from '../data/research-areas.json'; import type { ResearchArea } from '../types';
const researchAreas = areas as ResearchArea[];
---
<BaseLayout title="Research"><PageTitle title="Research" description="Research interests spanning learning, optimization, vision, and intelligent systems." /><Section><div class="grid gap-5 md:grid-cols-2">{researchAreas.map((area) => <Card><h2 class="font-serif text-2xl font-bold text-navy-900">{area.title}</h2><p class="mt-3 leading-7">{area.description ?? ''}</p><div class="mt-4 flex flex-wrap gap-2">{(area.keywords ?? []).map((keyword) => <span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-medium text-navy-800">{keyword}</span>)}</div></Card>)}</div></Section></BaseLayout>
