---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import courses from '../data/courses.json'; import type { Course } from '../types';
const levels = ['Undergraduate', 'Graduate', 'PhD'];
const courseRecords = courses as Course[];
---
<BaseLayout title="Teaching"><PageTitle title="Teaching" description="Teaching activities include undergraduate and graduate courses in data science, artificial intelligence, machine learning, optimization, and computer engineering." /><Section><div class="space-y-10">{levels.map((level) => <div><h2 class="mb-4 font-serif text-2xl font-bold text-navy-900">{level}</h2><div class="grid gap-4 md:grid-cols-2">{courseRecords.filter((course) => course.level === level).map((course) => <article class="rounded-lg border border-slate-200 bg-white p-5"><p class="text-sm font-semibold text-navy-600">{course.code ?? 'Course code'} · {course.language ?? 'Language not specified'}</p><h3 class="mt-2 text-lg font-semibold text-navy-900">{course.title}</h3><p class="mt-2 text-sm leading-6">{course.description ?? ''}</p><p class="mt-3 text-sm font-semibold text-navy-900">Topics</p><p class="text-sm">{(course.topics ?? []).join(' · ')}</p></article>)}</div></div>)}</div></Section></BaseLayout>
