---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import Card from '../components/Card.astro'; import projects from '../data/projects.json';
---
<BaseLayout title="Projects"><PageTitle title="Projects" description="Research and applied AI initiatives." /><Section><div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">{projects.map(p => <Card><p class="text-xs font-semibold uppercase tracking-wide text-navy-600">{p.status} · {p.year}</p><h2 class="mt-2 text-xl font-semibold text-navy-900">{p.title}</h2><dl class="mt-3 space-y-1 text-sm"><div><dt class="inline font-semibold">Role: </dt><dd class="inline">{p.role}</dd></div><div><dt class="inline font-semibold">Funding: </dt><dd class="inline">{p.fundingBody}</dd></div></dl><p class="mt-3 leading-7">{p.description}</p><p class="mt-4 text-sm font-semibold text-navy-900">Keywords</p><div class="mt-2 flex flex-wrap gap-2">{p.keywords.map(k => <span class="rounded-full bg-navy-50 px-2 py-1 text-xs text-navy-800">{k}</span>)}</div><p class="mt-4 text-sm font-semibold text-navy-900">Outputs</p><ul class="mt-1 list-disc pl-5 text-sm">{p.outputs.map(output => <li>{output}</li>)}</ul></Card>)}</div></Section></BaseLayout>
