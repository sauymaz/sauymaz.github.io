---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import Card from '../components/Card.astro'; import projects from '../data/projects.json'; import type { Project } from '../types';
const projectRecords = projects as Project[];
---
<BaseLayout title="Projects"><PageTitle title="Projects" description="Research and applied AI initiatives." /><Section><p class="mb-6 max-w-3xl text-sm leading-6 text-slate-600">Project records are maintained in <code>src/data/projects.json</code>. Add verified funding, role, date, output, and status information as project details become available.</p><div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">{projectRecords.map((project) => <Card><p class="text-xs font-semibold uppercase tracking-wide text-navy-600">{project.status ?? 'Not specified'} · {project.year ?? 'Not specified'}</p><h2 class="mt-2 text-xl font-semibold text-navy-900">{project.title}</h2><dl class="mt-3 space-y-1 text-sm"><div><dt class="inline font-semibold">Role: </dt><dd class="inline">{project.role ?? 'Not specified'}</dd></div><div><dt class="inline font-semibold">Funding: </dt><dd class="inline">{project.fundingBody ?? 'Not specified'}</dd></div></dl><p class="mt-3 leading-7">{project.description ?? ''}</p><p class="mt-4 text-sm font-semibold text-navy-900">Keywords</p><div class="mt-2 flex flex-wrap gap-2">{(project.keywords ?? []).map((keyword) => <span class="rounded-full bg-navy-50 px-2 py-1 text-xs text-navy-800">{keyword}</span>)}</div><p class="mt-4 text-sm font-semibold text-navy-900">Outputs</p><ul class="mt-1 list-disc pl-5 text-sm">{(project.outputs ?? []).map((output) => <li>{output}</li>)}</ul></Card>)}</div></Section></BaseLayout>
