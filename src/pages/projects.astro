---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import projects from '../data/projects.json';
import type { Project } from '../types';

const projectRecords = projects as Project[];
const sortedProjects = [...projectRecords].sort((a, b) => (b.startDate ?? '').localeCompare(a.startDate ?? ''));
const dateRange = (project: Project) => {
  if (project.startDate && project.endDate) return `${project.startDate} - ${project.endDate}`;
  return project.startDate ?? project.endDate ?? '';
};
---
<BaseLayout title="Projects" description="Research projects and academic project information for Sait Ali UYMAZ.">
  <PageTitle title="Projects" description="Research and academic project information." />
  <Section>
    <p class="mb-8 max-w-3xl text-sm leading-6 text-slate-600">Project records are maintained in <code>src/data/projects.json</code>. Add verified project information as it becomes available.</p>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {sortedProjects.map((project) => <Card>
        <div class="flex flex-wrap items-start justify-between gap-3"><h2 class="font-serif text-xl font-bold text-navy-900">{project.title}</h2>{project.status && <span class="rounded-full bg-navy-100 px-3 py-1 text-xs font-semibold text-navy-800">{project.status}</span>}</div>
        <dl class="mt-5 space-y-3 text-sm">
          {(project.projectType || project.fundingSource) && <div><dt class="font-semibold text-navy-900">Project type / funding source</dt><dd class="mt-1">{[project.projectType, project.fundingSource].filter(Boolean).join(' / ')}</dd></div>}
          {project.role && <div><dt class="font-semibold text-navy-900">Role</dt><dd class="mt-1">{project.role}</dd></div>}
          {dateRange(project) && <div><dt class="font-semibold text-navy-900">Date range</dt><dd class="mt-1">{dateRange(project)}</dd></div>}
          {project.status && <div><dt class="font-semibold text-navy-900">Status</dt><dd class="mt-1">{project.status}</dd></div>}
        </dl>
        {(project.keywords ?? []).length > 0 && <div class="mt-5"><p class="text-sm font-semibold text-navy-900">Keywords</p><div class="mt-2 flex flex-wrap gap-2">{(project.keywords ?? []).map((keyword) => <span class="rounded-full bg-navy-50 px-2 py-1 text-xs text-navy-800">{keyword}</span>)}</div></div>}
      </Card>)}
    </div>
  </Section>
</BaseLayout>
