---
import BaseLayout from '../layouts/BaseLayout.astro'; import Section from '../components/Section.astro'; import Card from '../components/Card.astro';
import profile from '../data/profile.json'; import areas from '../data/research-areas.json'; import publications from '../data/publications.json'; import projects from '../data/projects.json';
const links = Object.entries(profile.profiles).map(([label, url]) => [label.replace(/([A-Z])/g, ' $1').trim(), url]);
---
<BaseLayout>
  <section class="border-b border-slate-200 bg-white"><div class="mx-auto max-w-6xl px-5 py-16 sm:py-24"><p class="mb-4 font-semibold uppercase tracking-[0.18em] text-navy-600">{profile.title}</p><h1 class="font-serif text-5xl font-bold tracking-tight text-navy-900 sm:text-6xl">{profile.name}</h1><p class="mt-6 max-w-3xl text-xl leading-8 text-slate-700">{profile.department}<br />{profile.faculty}<br />{profile.institution}</p><p class="mt-7 max-w-2xl leading-7 text-slate-600">Researcher in artificial intelligence, machine learning, metaheuristic optimization, computer vision, and data-driven decision support systems.</p><a class="mt-8 inline-block rounded bg-navy-800 px-5 py-3 font-semibold text-white no-underline hover:bg-navy-700" href="/research">Explore research</a></div></section>
  <Section title="Research areas"><div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">{areas.slice(0, 6).map(area => <Card><h3 class="font-semibold text-navy-900">{area.title}</h3><p class="mt-2 text-sm leading-6">{area.description}</p></Card>)}</div></Section>
  <section class="bg-navy-900"><div class="mx-auto max-w-6xl px-5 py-12 sm:py-16"><p class="font-semibold uppercase tracking-[0.18em] text-navy-100">Featured research</p><h2 class="mt-3 font-serif text-3xl font-bold text-white">Artificial Algae Algorithm</h2><p class="mt-4 max-w-2xl leading-7 text-slate-200">A nature-inspired metaheuristic optimization approach motivated by the adaptive behavior of algal colonies.</p><a class="mt-6 inline-block rounded border border-white/60 px-5 py-3 font-semibold text-white no-underline hover:bg-white hover:text-navy-900" href="/artificial-algae-algorithm">Learn about AAA</a></div></section>
  <Section title="Featured publications"><div class="grid gap-4 md:grid-cols-3">{publications.filter(p => p.featured).map(p => <Card><p class="text-sm font-semibold text-navy-600">{p.year} · {p.type}</p><h3 class="mt-2 font-semibold text-navy-900">{p.title}</h3><p class="mt-2 text-sm italic">{p.venue}</p></Card>)}</div><a class="mt-6 inline-block font-semibold" href="/publications">View all publications →</a></Section>
  <Section title="Featured projects"><div class="grid gap-4 md:grid-cols-3">{projects.filter(p => p.featured).map(p => <Card><p class="text-xs font-semibold uppercase tracking-wide text-navy-600">{p.status}</p><h3 class="mt-2 font-semibold text-navy-900">{p.title}</h3><p class="mt-2 text-sm leading-6">{p.description}</p></Card>)}</div></Section>
  <Section title="Academic profiles"><div class="flex flex-wrap gap-x-5 gap-y-3">{links.map(([label, url]) => <a href={url} target="_blank" rel="noreferrer" class="font-medium">{label} <span aria-hidden="true">↗</span></a>)}</div></Section>
</BaseLayout>
