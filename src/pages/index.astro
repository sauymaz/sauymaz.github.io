---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import profile from '../data/profile.json';
import areas from '../data/research-areas.json';
import publications from '../data/publications.json';
import projects from '../data/projects.json';
import type { Project, Publication, ResearchArea } from '../types';

const links = Object.entries(profile.profiles).map(([label, url]) => [label.replace(/([A-Z])/g, ' $1').trim(), url]);
const researchAreas = areas as ResearchArea[];
const featuredPublications = (publications as Publication[]).filter((publication) => publication.featured).slice(0, 3);
const featuredProjects = (projects as Project[]).filter((project) => project.featured).slice(0, 3);
---
<BaseLayout title="Sait Ali UYMAZ" description="Academic website of Assoc. Prof. Dr. Sait Ali UYMAZ, researcher in artificial intelligence, machine learning, optimization, and applied intelligent systems.">
  <section class="border-b border-slate-200 bg-white"><div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 sm:py-24 md:grid-cols-[1fr_auto]"><div><p class="mb-4 font-semibold uppercase tracking-[0.18em] text-navy-600">{profile.title}</p><h1 class="font-serif text-5xl font-bold tracking-tight text-navy-900 sm:text-6xl">{profile.name}</h1><p class="mt-6 max-w-3xl text-xl leading-8 text-slate-700">{profile.department}<br />{profile.faculty}<br />{profile.institution}</p><p class="mt-7 max-w-3xl leading-7 text-slate-600">{profile.biography[0]}</p><a class="mt-8 inline-block rounded bg-navy-800 px-5 py-3 font-semibold text-white no-underline hover:bg-navy-700" href="/research">Explore research</a></div><div class="relative mx-auto h-52 w-52 sm:h-64 sm:w-64"><div class="flex h-full w-full items-center justify-center rounded-full border-4 border-navy-100 bg-navy-50 font-serif text-4xl font-bold text-navy-700 shadow-sm" role="img" aria-label={`Portrait placeholder for ${profile.title} ${profile.name}`}>SAU</div><img src="/images/profile.jpg" alt={`Portrait of ${profile.title} ${profile.name}`} class="absolute inset-0 h-full w-full rounded-full border-4 border-navy-100 object-cover object-[50%_22%] shadow-sm" onerror="this.remove()" /></div></div></section>
  <Section title="Research areas"><div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">{researchAreas.slice(0, 6).map((area) => <Card><h3 class="font-semibold text-navy-900">{area.title}</h3><p class="mt-2 text-sm leading-6">{area.description ?? ''}</p></Card>)}</div></Section>
  <section class="bg-navy-900"><div class="mx-auto max-w-6xl px-5 py-12 sm:py-16"><p class="font-semibold uppercase tracking-[0.18em] text-navy-100">Featured research</p><h2 class="mt-3 font-serif text-3xl font-bold text-white">Artificial Algae Algorithm</h2><p class="mt-4 max-w-3xl leading-7 text-slate-200">The Artificial Algae Algorithm is a bio-inspired, population-based approach to metaheuristic optimization. It represents candidate solutions as adaptive algal colonies and balances exploration with exploitation through fitness-based search behaviour.</p><a class="mt-6 inline-block rounded border border-white/60 px-5 py-3 font-semibold text-white no-underline hover:bg-white hover:text-navy-900" href="/artificial-algae-algorithm">Learn about AAA</a></div></section>
  <Section title="Featured publications"><div class="grid gap-4 md:grid-cols-3">{featuredPublications.map((publication) => <Card><p class="text-sm font-semibold text-navy-600">{publication.year} · {publication.publicationType}</p><h3 class="mt-2 font-semibold text-navy-900">{publication.title}</h3><p class="mt-2 text-sm italic">{publication.venue}</p></Card>)}</div><a class="mt-6 inline-block font-semibold" href="/publications">View all publications →</a></Section>
  <Section title="Featured projects"><div class="grid gap-4 md:grid-cols-3">{featuredProjects.map((project) => <Card><p class="text-xs font-semibold uppercase tracking-wide text-navy-600">{project.status ?? 'Not specified'}</p><h3 class="mt-2 font-semibold text-navy-900">{project.title}</h3>{(project.projectType || project.fundingSource) && <p class="mt-2 text-sm leading-6">{[project.projectType, project.fundingSource].filter(Boolean).join(' / ')}</p>}</Card>)}</div></Section>
  <Section title="Academic profiles"><div class="flex flex-wrap gap-x-5 gap-y-3">{links.map(([label, url]) => <a href={url} target="_blank" rel="noreferrer" class="font-medium">{label} <span aria-hidden="true">↗</span></a>)}</div></Section>
</BaseLayout>
