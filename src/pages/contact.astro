---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import profile from '../data/profile.json';
---
<BaseLayout title="Contact"><PageTitle title="Contact" description="Get in touch for research, teaching, and academic collaboration." /><Section><div class="max-w-2xl rounded-lg border border-slate-200 bg-white p-6 leading-8"><p class="font-serif text-2xl font-bold text-navy-900">{profile.title} {profile.name}</p><p class="mt-3">{profile.department}<br />{profile.faculty}<br />{profile.institution}</p><p class="mt-5"><a href={`mailto:${profile.email}`}>{profile.email}</a></p><p class="mt-2"><a href={`https://${profile.domain}`}>{profile.domain}</a></p></div></Section></BaseLayout>
