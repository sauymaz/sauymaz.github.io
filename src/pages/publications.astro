---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import publications from '../data/publications.json';
import type { Publication } from '../types';

const publicationRecords = publications as Publication[];
const byYear = (records: Publication[]) => [...records].sort((a, b) => b.year - a.year);
const categoryText = (publication: Publication) => publication.category.toLowerCase();
const isConference = (publication: Publication) => categoryText(publication).includes('conference');
const isBook = (publication: Publication) => categoryText(publication).includes('book');
const groups = [
  { title: 'Articles', records: byYear(publicationRecords.filter((publication) => !isConference(publication) && !isBook(publication))) },
  { title: 'Conference Papers', records: byYear(publicationRecords.filter(isConference)) },
  { title: 'Books & Book Chapters', records: byYear(publicationRecords.filter(isBook)) },
];
---
<BaseLayout title="Publications" description="Publications by Sait Ali UYMAZ, organised as articles, conference papers, and books or book chapters.">
  <PageTitle title="Publications" description="Selected scholarly work organised by publication category." />
  <Section>
    <p class="mb-10 max-w-3xl text-sm leading-6 text-slate-600">This list is structured for future YOK Akademik imports. Update <code>src/data/publications.json</code> with verified bibliographic metadata and source information.</p>
    <div class="space-y-12">
      {groups.map((group) => <section>
        <h2 class="mb-5 font-serif text-2xl font-bold text-navy-900">{group.title}</h2>
        {group.records.length > 0 ? <div class="space-y-4">{group.records.map((publication) => <Card>
          <div class="flex flex-wrap items-start justify-between gap-3"><div><p class="text-sm font-semibold text-navy-600">{publication.year} · {publication.category}</p><h3 class="mt-1 text-lg font-semibold text-navy-900">{publication.title}</h3></div>{publication.featured && <span class="rounded-full bg-navy-100 px-3 py-1 text-xs font-semibold text-navy-800">Featured</span>}</div>
          <p class="mt-3">{publication.authors}</p><p class="mt-1 italic text-slate-600">{publication.venue}</p>
          <div class="mt-3 flex flex-wrap gap-2"><span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">{publication.publicationType}</span>{(publication.keywords ?? []).map((keyword) => <span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-medium text-navy-800">{keyword}</span>)}</div>
          {(publication.volume || publication.issue || publication.pages) && <p class="mt-4 text-sm text-slate-600">{publication.volume && `Vol. ${publication.volume}`}{publication.issue && `, Issue ${publication.issue}`}{publication.pages && `, pp. ${publication.pages}`}</p>}
          {publication.presentationType && <p class="mt-2 text-sm text-slate-600">Presentation: {publication.presentationType}</p>}{publication.isbn && <p class="mt-2 text-sm text-slate-600">ISBN: {publication.isbn}</p>}
          <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm">{publication.doi && <a href={`https://doi.org/${publication.doi}`} target="_blank" rel="noreferrer">DOI: {publication.doi} ↗</a>}{publication.url && <a href={publication.url} target="_blank" rel="noreferrer">Publication link ↗</a>}</div>
        </Card>)}</div> : <p class="rounded-lg border border-dashed border-slate-300 bg-white p-5 text-sm text-slate-600">Verified records will be listed here as publication data is imported.</p>}
      </section>)}
    </div>
  </Section>
</BaseLayout>
