---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import Card from '../components/Card.astro'; import publications from '../data/publications.json';
const sortedPublications = [...publications].sort((a, b) => b.year - a.year);
---
<BaseLayout title="Publications"><PageTitle title="Publications" description="Selected scholarly work. Complete bibliographic records will be added here." /><Section><div class="mb-6 flex flex-wrap gap-2" aria-label="Publication type filter"><span class="mr-2 self-center text-sm font-medium text-slate-600">Filter:</span><button class="rounded-full bg-navy-800 px-3 py-1 text-sm font-semibold text-white" type="button">All</button><button class="rounded-full border border-slate-300 px-3 py-1 text-sm text-slate-700" type="button">Articles</button><button class="rounded-full border border-slate-300 px-3 py-1 text-sm text-slate-700" type="button">Conferences</button></div><div class="space-y-4">{sortedPublications.map(p => <Card><p class="text-sm font-semibold text-navy-600">{p.year} · {p.type}</p><h2 class="mt-2 text-lg font-semibold text-navy-900">{p.title}</h2><p class="mt-2">{p.authors}</p><p class="mt-1 italic text-slate-600">{p.venue}</p>{p.doi && <a class="mt-3 inline-block text-sm" href={`https://doi.org/${p.doi}`}>DOI: {p.doi}</a>}{p.url && <a class="mt-3 inline-block text-sm" href={p.url}>Publication link ↗</a>}</Card>)}</div></Section></BaseLayout>
