---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import Card from '../components/Card.astro'; import publications from '../data/publications.json'; import type { Publication } from '../types';
const publicationRecords = publications as Publication[];
const sortedPublications = [...publicationRecords].sort((a, b) => b.year - a.year);
---
<BaseLayout title="Publications"><PageTitle title="Publications" description="Selected scholarly work. Complete bibliographic records will be added here." /><Section><p class="mb-6 max-w-3xl text-sm leading-6 text-slate-600">This list is structured for future YOK Akademik imports. Update <code>src/data/publications.json</code> with verified author, venue, DOI, and URL records.</p><div class="mb-6 flex flex-wrap gap-2" aria-label="Publication type filter"><span class="mr-2 self-center text-sm font-medium text-slate-600">Filter:</span><button class="rounded-full bg-navy-800 px-3 py-1 text-sm font-semibold text-white" type="button">All</button><button class="rounded-full border border-slate-300 px-3 py-1 text-sm text-slate-700" type="button">Articles</button><button class="rounded-full border border-slate-300 px-3 py-1 text-sm text-slate-700" type="button">Conferences</button></div><div class="space-y-4">{sortedPublications.map((publication) => <Card><p class="text-sm font-semibold text-navy-600">{publication.year} · {publication.type}</p><h2 class="mt-2 text-lg font-semibold text-navy-900">{publication.title}</h2><p class="mt-2">{publication.authors}</p><p class="mt-1 italic text-slate-600">{publication.venue}</p>{publication.doi && <a class="mt-3 inline-block text-sm" href={`https://doi.org/${publication.doi}`}>DOI: {publication.doi}</a>}{publication.url && <a class="mt-3 inline-block text-sm" href={publication.url}>Publication link ↗</a>}</Card>)}</div></Section></BaseLayout>
