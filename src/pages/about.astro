---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import profile from '../data/profile.json';
---
<BaseLayout title="About" description="Biography and academic profile of Assoc. Prof. Dr. Sait Ali UYMAZ."><PageTitle title="About" description="Academic profile and institutional affiliation." /><Section><div class="grid gap-8 lg:grid-cols-[2fr_1fr]"><div class="space-y-8 leading-8"><div class="flex flex-col gap-6 sm:flex-row"><img src="/images/profile.jpg" alt={`Portrait of ${profile.title} ${profile.name}`} class="h-32 w-32 shrink-0 rounded-2xl object-cover object-[50%_22%] shadow-sm" onerror="this.remove()" /><div><h2 class="font-serif text-2xl font-bold text-navy-900">Biography</h2><p class="mt-3"><strong>{profile.title} {profile.name}</strong> is an academic at {profile.institution}, working in artificial intelligence, machine learning, optimization, and data-driven intelligent systems.</p></div></div><div><h2 class="font-serif text-2xl font-bold text-navy-900">Research Interests</h2><p class="mt-3">{profile.researchInterests.join(', ')}.</p></div><div><h2 class="font-serif text-2xl font-bold text-navy-900">Administrative Roles</h2><ul class="mt-3 list-disc space-y-2 pl-5">{profile.administrativeRoles.map(role => <li>{role}</li>)}</ul><p class="mt-3 text-slate-600">These roles support interdisciplinary research activity through the Artificial Intelligence Application and Research Center and KTUN AI-Lab.</p></div></div><aside class="space-y-6 rounded-lg border border-slate-200 bg-white p-6"><div><h2 class="font-serif text-xl font-bold text-navy-900">Academic Position</h2><p class="mt-2">{profile.academicPosition}</p></div><div><h2 class="font-serif text-xl font-bold text-navy-900">Academic Profiles</h2><ul class="mt-2 space-y-2">{Object.entries(profile.profiles).map(([label, url]) => <li><a href={url} target="_blank" rel="noreferrer">{label.replace(/([A-Z])/g, ' $1').trim()} ↗</a></li>)}</ul></div></aside></div></Section></BaseLayout>
