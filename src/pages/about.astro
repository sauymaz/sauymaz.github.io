---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageTitle from '../components/PageTitle.astro'; import Section from '../components/Section.astro'; import profile from '../data/profile.json';
---
<BaseLayout title="About" description="Biography and academic profile of Assoc. Prof. Dr. Sait Ali UYMAZ."><PageTitle title="About" description="Academic profile and institutional affiliation." /><Section><div class="grid gap-8 lg:grid-cols-[2fr_1fr]"><div class="space-y-8 leading-8"><div><h2 class="font-serif text-2xl font-bold text-navy-900">Biography</h2><p class="mt-3"><strong>{profile.title} {profile.name}</strong> is a faculty member in the {profile.department}, {profile.faculty}, at {profile.institution}. His work connects artificial intelligence, learning, optimization, and visual computing to practical research problems.</p></div><div><h2 class="font-serif text-2xl font-bold text-navy-900">Research Interests</h2><p class="mt-3">Artificial intelligence, machine learning, deep learning, metaheuristic optimization, medical image segmentation, federated learning, and industrial AI applications.</p></div><div><h2 class="font-serif text-2xl font-bold text-navy-900">Administrative Roles</h2><p class="mt-3 text-slate-600">Academic and administrative roles will be listed here as they are confirmed.</p></div></div><aside class="space-y-6 rounded-lg border border-slate-200 bg-white p-6"><div><h2 class="font-serif text-xl font-bold text-navy-900">Academic Position</h2><p class="mt-2">{profile.title}<br />{profile.department}<br />{profile.institution}</p></div><div><h2 class="font-serif text-xl font-bold text-navy-900">Academic Profiles</h2><ul class="mt-2 space-y-2">{Object.entries(profile.profiles).map(([label, url]) => <li><a href={url} target="_blank" rel="noreferrer">{label.replace(/([A-Z])/g, ' $1').trim()} ↗</a></li>)}</ul></div></aside></div></Section></BaseLayout>
