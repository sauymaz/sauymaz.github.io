---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import aaa from '../../data/aaa-info.json';
const publication = aaa.publication;
---
<BaseLayout title="Artificial Algae Algorithm | Bio-inspired Metaheuristic Optimization" description="Artificial Algae Algorithm (AAA) is a bio-inspired population-based metaheuristic optimization algorithm proposed for nonlinear global optimization. Learn about its biological inspiration, helical movement, evolutionary process, adaptation mechanism, code implementations, and citation information.">
  <PageTitle title="Artificial Algae Algorithm" description={aaa.subtitle} />
  <Section title="Original Publication"><Card class="max-w-4xl border-navy-100"><p class="text-sm font-semibold text-navy-600">{publication.year} · {publication.journal}</p><h2 class="mt-2 font-serif text-2xl font-bold text-navy-900">{publication.title}</h2><p class="mt-3">{publication.authors}</p><dl class="mt-4 grid gap-3 text-sm sm:grid-cols-3"><div><dt class="font-semibold text-navy-900">Volume</dt><dd>{publication.volume}</dd></div><div><dt class="font-semibold text-navy-900">Pages</dt><dd>{publication.pages}</dd></div><div><dt class="font-semibold text-navy-900">DOI</dt><dd><a href={`https://doi.org/${publication.doi}`}>{publication.doi}</a></dd></div></dl><a class="mt-5 inline-block font-semibold" href={publication.url} target="_blank" rel="noreferrer">View on ScienceDirect ↗</a></Card></Section>
  <Section title="Overview" class="bg-white"><p class="max-w-3xl leading-8">Proposed in <em>Applied Soft Computing</em> in 2015, AAA is a population-based approach to nonlinear global optimization. It is inspired by selected living behaviours of microalgae, modelling colonies as candidate solutions that move, grow, reproduce, and adapt during the search process.</p></Section>
  <Section title="Biological Inspiration"><div class="max-w-3xl space-y-4 leading-8"><p>Microalgae move toward light to support photosynthesis and can exhibit helical swimming behaviour. Under suitable light and nutrient conditions they grow and reproduce, while adapting to changing environmental conditions.</p><p>AAA translates these selected behaviours into computational mechanisms for exploring a search space and improving candidate solutions.</p></div></Section>
  <Section title="Main Components" class="bg-white"><p class="mb-6 max-w-3xl leading-8">{aaa.mechanism}</p><div class="grid gap-5 md:grid-cols-3">{aaa.components.map(component => <Card><h3 class="font-serif text-xl font-bold text-navy-900">{component.title}</h3><p class="mt-3 text-sm leading-7">{component.description}</p></Card>)}</div></Section>
  <Section title="Algorithm Flow"><ol class="max-w-3xl list-decimal space-y-2 pl-5 leading-7"><li>Determine parameters: shear force, energy loss, and adaptation parameter.</li><li>Initialize artificial algae colonies.</li><li>Evaluate fitness and colony sizes.</li><li>Perform helical movement while energy remains.</li><li>Update starvation values.</li><li>Apply the evolutionary process.</li><li>Apply the adaptation process.</li><li>Keep the best colony.</li><li>Check the stopping criterion.</li><li>Return the optimum solution.</li></ol></Section>
  <Section title="Pseudocode" class="bg-white"><pre class="max-w-4xl overflow-x-auto rounded-lg bg-navy-900 p-5 text-sm leading-7 text-slate-100"><code>Set shear force, energy loss, and adaptation parameter
Initialize artificial algae colonies
Evaluate fitness and determine colony sizes
while stopping criterion is not met:
    perform helical movement while energy remains
    update starvation values
    apply evolutionary process
    apply adaptation process
    preserve the best colony found
return the optimum solution</code></pre></Section>
  <Section title="Benchmarking and Validation"><ul class="grid gap-3 sm:grid-cols-2">{aaa.benchmarking.map(item => <li class="rounded border border-slate-200 bg-white p-4">{item}</li>)}</ul></Section>
  <Section title="Applications" class="bg-white"><ul class="grid gap-3 sm:grid-cols-2">{aaa.applications.map(item => <li class="rounded border border-slate-200 p-4">{item}</li>)}</ul></Section>
  <Section title="Implementations"><p class="mb-5 max-w-3xl leading-7">MATLAB and Python implementation materials will be provided through the separate public repository.</p><div class="flex flex-wrap gap-3"><a href="/artificial-algae-algorithm/code" class="rounded bg-navy-800 px-4 py-2 font-semibold text-white no-underline">AAA Code</a><a href="/artificial-algae-algorithm/citations" class="rounded border border-navy-800 px-4 py-2 font-semibold no-underline">AAA Citations</a><a href="/artificial-algae-algorithm/how-to-cite" class="rounded border border-navy-800 px-4 py-2 font-semibold no-underline">How to Cite AAA</a></div></Section>
  <Section title="Citation" class="bg-navy-900"><p class="max-w-3xl leading-7 text-slate-200">Please cite the original AAA publication when using the method in research. The article PDF should not be redistributed here unless copyright permissions allow it; use the DOI or ScienceDirect link instead.</p><a class="mt-5 inline-block rounded border border-white/60 px-4 py-2 font-semibold text-white no-underline hover:bg-white hover:text-navy-900" href="/artificial-algae-algorithm/how-to-cite">Copy citation formats</a></Section>
</BaseLayout>
