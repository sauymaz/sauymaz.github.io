---
import BaseLayout from '../../layouts/BaseLayout.astro'; import PageTitle from '../../components/PageTitle.astro'; import Section from '../../components/Section.astro'; import Card from '../../components/Card.astro'; import citations from '../../data/aaa-citations.json';
---
<BaseLayout title="AAA Citations" description="Original publication and citation information for the Artificial Algae Algorithm."><PageTitle title="AAA Citations" description="Original publication and citation information for the Artificial Algae Algorithm." /><Section><div class="space-y-4">{citations.map(citation => <Card><p class="text-sm font-semibold text-navy-600">Original publication · {citation.year}</p><h2 class="mt-2 text-lg font-semibold text-navy-900">{citation.title}</h2><p class="mt-2">{citation.authors}</p><p class="mt-1 italic text-slate-600">{citation.journal}, vol. {citation.volume}, pp. {citation.pages}</p><p class="mt-3 text-sm leading-6 text-slate-600">{citation.note}</p><div class="mt-4 flex flex-wrap gap-4 text-sm"><a href={`https://doi.org/${citation.doi}`} target="_blank" rel="noreferrer">DOI: {citation.doi} ↗</a><a href={citation.url} target="_blank" rel="noreferrer">ScienceDirect ↗</a></div></Card>)}</div><p class="mt-8 text-sm text-slate-500">Additional studies using AAA can be added to <code>src/data/aaa-citations.json</code> as verified records become available.</p></Section></BaseLayout>
