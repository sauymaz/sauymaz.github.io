---
import BaseLayout from '../../layouts/BaseLayout.astro'; import PageTitle from '../../components/PageTitle.astro'; import Section from '../../components/Section.astro'; import Card from '../../components/Card.astro'; import citations from '../../data/aaa-citations.json';
---
<BaseLayout title="AAA Citations"><PageTitle title="AAA Citations" description="Studies and resources using the Artificial Algae Algorithm." /><Section><div class="space-y-4">{citations.map(citation => <Card><p class="text-sm font-semibold text-navy-600">Study using AAA · {citation.year}</p><h2 class="mt-2 text-lg font-semibold text-navy-900">{citation.title}</h2><p class="mt-3 text-sm leading-6 text-slate-600">{citation.note}</p></Card>)}</div></Section></BaseLayout>
