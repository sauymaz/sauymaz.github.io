---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import citations from '../../data/aaa-citations.json';
import type { AaaCitation } from '../../types';

const citationRecords = citations as AaaCitation[];
const verifiedCitations = citationRecords.filter((citation) => citation.verified);
const sortedCitations = [...verifiedCitations].sort((a, b) => (b.year ?? 0) - (a.year ?? 0));
---
<BaseLayout title="AAA Citations" description="Curated and verified studies that cite, use, improve, compare with, hybridize, or review the Artificial Algae Algorithm.">
  <PageTitle title="AAA Citations" description="Subsequent studies related to the Artificial Algae Algorithm." />
  <Section>
    <div class="max-w-4xl space-y-4 leading-7">
      <p>This page lists studies that cite, use, compare, extend, or discuss the Artificial Algae Algorithm in optimization and related application domains.</p>
    </div>

    {sortedCitations.length > 0 ? (
      <div class="mt-8 space-y-5">
        {sortedCitations.map((citation) => <Card>
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-navy-600">{citation.year ?? 'Year not specified'}</p>
              <h2 class="mt-1 font-serif text-xl font-bold text-navy-900">{citation.title}</h2>
            </div>
            <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800">Verified</span>
          </div>
          <p class="mt-3">{citation.authors ?? 'Authors not specified'}</p>
          <p class="mt-1 italic text-slate-600">{citation.venue ?? 'Venue not specified'}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-medium text-navy-800">{citation.usageType ?? 'Usage not specified'}</span>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">{citation.applicationArea ?? 'Area not specified'}</span>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">{citation.publicationType ?? 'Type not specified'}</span>
          </div>
          {citation.notes && <p class="mt-4 text-sm leading-6 text-slate-600">{citation.notes}</p>}
          <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm">
            {citation.doi && <a href={`https://doi.org/${citation.doi}`} target="_blank" rel="noreferrer">DOI: {citation.doi} ↗</a>}
            {citation.url && <a href={citation.url} target="_blank" rel="noreferrer">Publication link ↗</a>}
          </div>
          {citation.source && <p class="mt-4 border-t border-slate-100 pt-3 text-xs text-slate-500">Source: {citation.source}</p>}
        </Card>)}
      </div>
    ) : (
      <div class="mt-8 rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-slate-600">
        Studies citing, using, improving, comparing with, hybridizing, or reviewing the Artificial Algae Algorithm will be listed here after verification.
      </div>
    )}
  </Section>
</BaseLayout>
