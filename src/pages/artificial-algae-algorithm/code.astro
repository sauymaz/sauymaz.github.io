---
import BaseLayout from '../../layouts/BaseLayout.astro'; import PageTitle from '../../components/PageTitle.astro'; import Section from '../../components/Section.astro'; import Card from '../../components/Card.astro'; import code from '../../data/aaa-code.json';
---
<BaseLayout title="AAA Code"><PageTitle title="AAA Code" description="MATLAB and Python implementation resources for the Artificial Algae Algorithm." /><Section><div class="grid gap-5 md:grid-cols-2">{code.map(item => <Card><p class="text-sm font-semibold text-navy-600">{item.language}</p><h2 class="mt-2 text-xl font-semibold text-navy-900">{item.title}</h2><p class="mt-3 leading-7">{item.description}</p><div class="mt-4 flex gap-4"><a class="font-semibold" href={item.url} target="_blank" rel="noreferrer">View resource ↗</a><a class="font-semibold" href={item.repository} target="_blank" rel="noreferrer">GitHub placeholder ↗</a></div></Card>)}</div><p class="mt-8 text-sm text-slate-500">Code links are placeholders and should be replaced with release repositories or archived implementation packages.</p></Section></BaseLayout>
