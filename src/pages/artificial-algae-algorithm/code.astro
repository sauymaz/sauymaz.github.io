---
import BaseLayout from '../../layouts/BaseLayout.astro'; import PageTitle from '../../components/PageTitle.astro'; import Section from '../../components/Section.astro'; import Card from '../../components/Card.astro'; import code from '../../data/aaa-code.json'; import type { AaaCode } from '../../types';
const codeRecords = code as AaaCode[];
---
<BaseLayout title="AAA Code"><PageTitle title="AAA Code" description="MATLAB and Python implementation resources for the Artificial Algae Algorithm." /><Section><div class="grid gap-5 md:grid-cols-2">{codeRecords.map((item) => <Card><p class="text-sm font-semibold text-navy-600">{item.language}</p><h2 class="mt-2 text-xl font-semibold text-navy-900">{item.title}</h2><p class="mt-3 leading-7">{item.description ?? ''}</p><div class="mt-4 flex gap-4">{item.repository && <a class="font-semibold" href={item.repository} target="_blank" rel="noreferrer">AAA GitHub repository ↗</a>}</div></Card>)}</div><p class="mt-8 max-w-3xl text-sm leading-6 text-slate-500">Reference MATLAB and Python implementations will be published through the separate public repository. The original article PDF is not distributed here; use the DOI and ScienceDirect links on the citation page unless copyright permissions allow redistribution.</p></Section></BaseLayout>
